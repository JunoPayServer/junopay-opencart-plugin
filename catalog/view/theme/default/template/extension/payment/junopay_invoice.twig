{{ header }}
<div id="common-success" class="container">
  <div class="row">{{ column_left }}
    {% if column_left and column_right %}
    {% set class = 'col-sm-6' %}
    {% elseif column_left or column_right %}
    {% set class = 'col-sm-9' %}
    {% else %}
    {% set class = 'col-sm-12' %}
    {% endif %}
    <div id="content" class="{{ class }}">{{ content_top }}
      <style>
      .junopay-invoice {
        max-width: 760px;
        margin: 24px auto 48px;
        border: 1px solid #ded7cd;
        border-radius: 16px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 18px 50px rgba(35, 25, 16, 0.12);
      }
      .junopay-invoice__header {
        background: #191715;
        color: #fff;
        padding: 28px;
      }
      .junopay-invoice__brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .junopay-invoice__mark {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f59a3d;
        color: #fff;
        font-weight: 800;
        font-size: 24px;
      }
      .junopay-invoice h1 {
        margin: 0;
        color: #fff;
        font-size: 26px;
        font-weight: 800;
      }
      .junopay-invoice__status {
        display: inline-block;
        margin-top: 16px;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(245, 154, 61, 0.16);
        color: #ffd5a7;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
      }
      .junopay-invoice__body {
        padding: 28px;
      }
      .junopay-invoice__lead {
        margin: 0 0 22px;
        color: #5f574f;
        font-size: 16px;
      }
      .junopay-invoice__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
      }
      .junopay-invoice__field {
        border: 1px solid #e6e0d8;
        border-radius: 12px;
        padding: 14px;
        background: #fbfaf8;
      }
      .junopay-invoice__label {
        margin: 0 0 8px;
        color: #847a70;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
      }
      .junopay-invoice__value-row {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .junopay-invoice__value {
        min-width: 0;
        flex: 1;
        margin: 0;
        color: #211d18;
        font-family: Menlo, Monaco, Consolas, "Courier New", monospace;
        font-size: 15px;
        word-break: break-all;
      }
      .junopay-invoice__amount {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: 0;
      }
      .junopay-copy {
        border: 1px solid #d8843f;
        border-radius: 8px;
        background: #fff;
        color: #a45c1f;
        font-weight: 700;
        padding: 8px 10px;
      }
      .junopay-invoice__hint {
        margin: 18px 0 0;
        color: #6b6259;
      }
      @media (max-width: 640px) {
        .junopay-invoice { margin: 12px 0 32px; border-radius: 12px; }
        .junopay-invoice__header, .junopay-invoice__body { padding: 20px; }
        .junopay-invoice__value-row { align-items: stretch; flex-direction: column; }
      }
      </style>
      <section class="junopay-invoice">
        <div class="junopay-invoice__header">
          <div class="junopay-invoice__brand">
            <div class="junopay-invoice__mark">J</div>
            <h1>{{ heading_title }}</h1>
          </div>
          <span class="junopay-invoice__status">{{ text_waiting }}</span>
        </div>
        <div class="junopay-invoice__body">
          <p class="junopay-invoice__lead">{{ text_exact }}</p>
          <div class="junopay-invoice__grid">
            <div class="junopay-invoice__field">
              <p class="junopay-invoice__label">{{ text_amount }}</p>
              <p class="junopay-invoice__value junopay-invoice__amount">{{ amount }}</p>
            </div>
            <div class="junopay-invoice__field">
              <p class="junopay-invoice__label">{{ text_address }}</p>
              <div class="junopay-invoice__value-row">
                <p class="junopay-invoice__value" data-junopay-copy-value>{{ address }}</p>
                <button type="button" class="junopay-copy" data-junopay-copy>{{ text_copy }}</button>
              </div>
            </div>
            <div class="junopay-invoice__field">
              <p class="junopay-invoice__label">{{ text_invoice }}</p>
              <p class="junopay-invoice__value">{{ invoice_id }}</p>
            </div>
          </div>
          <p class="junopay-invoice__hint">{{ text_wallet_hint }}</p>
        </div>
      </section>
      <div class="buttons">
        <div class="pull-right"><a href="{{ continue }}" class="btn btn-primary">Continue</a></div>
      </div>
      <script type="text/javascript">
      (function() {
        var button = document.querySelector('[data-junopay-copy]');
        var value = document.querySelector('[data-junopay-copy-value]');
        if (!button || !value) return;
        button.addEventListener('click', function() {
          var text = value.textContent.replace(/^\s+|\s+$/g, '');
          var done = function() {
            button.textContent = '{{ text_copied }}';
            setTimeout(function() { button.textContent = '{{ text_copy }}'; }, 1600);
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(done);
          } else {
            var input = document.createElement('textarea');
            input.value = text;
            document.body.appendChild(input);
            input.select();
            document.execCommand('copy');
            document.body.removeChild(input);
            done();
          }
        });
      })();
      </script>
      {{ content_bottom }}</div>
    {{ column_right }}</div>
</div>
{{ footer }}
